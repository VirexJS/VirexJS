{
	"name": "virexjs",
	"version": "0.1.0",
	"description": "Ship HTML, not JavaScript. A full-stack web framework built on Bun.",
	"type": "module",
	"main": "src/types/index.ts",
	"types": "src/types/index.ts",
	"exports": {
		".": "./src/types/index.ts",
		"./jsx-runtime": "./jsx-runtime.ts",
		"./jsx-dev-runtime": "./jsx-dev-runtime.ts",
		"./server": "./src/server/index.ts",
		"./server/middleware": "./src/server/middleware.ts",
		"./server/static": "./src/server/static.ts",
		"./server/handler": "./src/server/handler.ts",
		"./server/response": "./src/server/response.ts",
		"./render": "./src/render/index.ts",
		"./render/jsx": "./src/render/jsx.ts",
		"./render/meta": "./src/render/meta.ts",
		"./render/island-marker": "./src/render/island-marker.ts",
		"./render/index": "./src/render/index.ts",
		"./config": "./src/config/index.ts",
		"./config/types": "./src/config/types.ts",
		"./config/defaults": "./src/config/defaults.ts",
		"./compat/react": "./src/compat/react.ts",
		"./compat": "./src/compat/index.ts",
		"./plugin": "./src/plugin/index.ts",
		"./i18n": "./src/i18n/index.ts",
		"./testing": "./src/testing/index.ts"
	},
	"bin": {
		"virex": "src/cli/index.ts"
	},
	"files": [
		"src",
		"jsx-runtime.ts",
		"jsx-dev-runtime.ts"
	],
	"keywords": [
		"bun",
		"web-framework",
		"ssr",
		"islands",
		"jsx",
		"file-based-routing",
		"zero-js",
		"html-first",
		"server-rendering",
		"typescript"
	],
	"homepage": "https://github.com/virex-js/virexjs",
	"repository": {
		"type": "git",
		"url": "https://github.com/virex-js/virexjs.git",
		"directory": "packages/virexjs"
	},
	"bugs": "https://github.com/virex-js/virexjs/issues",
	"engines": {
		"bun": ">=1.2"
	},
	"license": "MIT",
	"author": "ECOSTACK TECHNOLOGY OÜ",
	"dependencies": {
		"@virexjs/router": "workspace:*",
		"@virexjs/bundler": "workspace:*",
		"@virexjs/db": "workspace:*"
	}
}
