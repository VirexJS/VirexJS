{
	"$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": ["packages/**", "playground/src/**", "playground/virex.config.ts"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": { "noExcessiveCognitiveComplexity": "off" },
			"suspicious": {
				"noExplicitAny": "warn",
				"noImplicitAnyLet": "warn",
				"noNonNullAssertedOptionalChain": "off"
			},
			"style": { "noNonNullAssertion": "off" }
		}
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": { "quoteStyle": "double", "semicolons": "always" }
	}
}
